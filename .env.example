# Skills Hub 环境配置示例
# 复制此文件为 .env 并修改配置

# 基础配置
APP_NAME=Skills Hub
DEBUG=false
RUN_MODE=login_required

# 数据库配置
DATABASE_TYPE=sqlite
SQLITE_DB_PATH=data/db/skills_hub.db

# 安全配置
SECRET_KEY=your-secret-key-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# 初始化管理模式（仅用于初始化）
BOOTSTRAP_TOKEN=

# 文件上传配置
MAX_FILE_SIZE_MB=50
MAX_TOTAL_UPLOAD_SIZE_MB=500
MAX_FILES_PER_UPLOAD=1000

# Git 配置
GIT_ALLOWED_DOMAINS=github.com,gitlab.com,bitbucket.org
GIT_SYNC_INTERVAL_HOURS=24

# 搜索配置
FULLTEXT_INDEX_PATH=data/index/fulltext
VECTOR_INDEX_PATH=data/index/vector
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# CORS 配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
